# Optional. API keys are not required for demo:offline.
# Use CURSOR_AGENT_COMMAND when Cursor exposes a local/CLI agent in your environment.
# CURSOR_API_KEY or fallback LLM keys can be referenced by that command.
CURSOR_API_KEY=
OPENAI_API_KEY=
CURSOR_AGENT_COMMAND=

# Relative or absolute command to run as the monitored target.
TARGET_COMMAND=node
TARGET_ARGS=target_app.js

# Deterministic demo scenario.
SCENARIO=malformed-json

# Safety limits.
MAX_FILE_BYTES=65536
MAX_WORKSPACE_FILES=80
READ_ONLY_MODE=true
